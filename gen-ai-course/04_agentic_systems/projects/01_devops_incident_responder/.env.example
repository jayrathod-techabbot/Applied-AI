# ============================================================================
# AI DevOps Incident Responder — Environment Variables
#
# Copy this file to .env and fill in the required values:
#   cp .env.example .env
#
# .env is loaded automatically by:
#   - Python code (python-dotenv: load_dotenv())
#   - Docker Compose (reads .env from project directory)
# ============================================================================

# ----------------------------------------------------------------------------
# LLM Configuration (REQUIRED)
# ----------------------------------------------------------------------------

# Your OpenAI API key — required for planner, diagnoser, and fix_proposer nodes
OPENAI_API_KEY=sk-...

# OpenAI model to use. GPT-4o is recommended for production-quality reasoning.
# Use gpt-4o-mini for lower cost during development.
OPENAI_MODEL=gpt-4o

# LLM provider. Currently only 'openai' is supported.
# Future: 'anthropic', 'azure', 'local' (Ollama)
LLM_PROVIDER=openai

# ----------------------------------------------------------------------------
# Data Paths
# ----------------------------------------------------------------------------

# Directory containing markdown runbook files
# Change this to point to your team's internal runbook repository
RUNBOOK_DIR=./data/runbooks

# Directory where resolved incident JSON files are persisted
# Ensure this directory is backed up or use a mounted volume in Docker
INCIDENT_HISTORY_DIR=./data/incident_history

# ----------------------------------------------------------------------------
# Agent Behavior
# ----------------------------------------------------------------------------

# Maximum number of ReAct iterations in the diagnoser node (default: 3)
# Higher values = more thorough diagnosis but higher cost and latency
# Minimum: 1, Recommended: 2-4, Maximum: 10
MAX_REACT_ITERATIONS=3

# If true (default), execute_fix() logs commands but does NOT execute them.
# Set to false only in environments where you want real command execution.
# WARNING: Setting DRY_RUN=false allows actual systemctl/kubectl commands to run!
DRY_RUN=true

# ----------------------------------------------------------------------------
# API Server (optional)
# ----------------------------------------------------------------------------

# Port for the FastAPI backend
API_PORT=8000

# Port for the Streamlit dashboard
STREAMLIT_PORT=8501

# URL the Streamlit UI uses to reach the FastAPI backend
# Change this if running UI and API on different hosts
API_BASE_URL=http://localhost:8000

# ----------------------------------------------------------------------------
# Logging (optional)
# ----------------------------------------------------------------------------

# Log level for uvicorn: debug | info | warning | error | critical
LOG_LEVEL=info
