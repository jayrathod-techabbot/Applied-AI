# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Select which LLM backend to use.
# Options: ollama (local, free) | openai (cloud, requires API key)
LLM_PROVIDER=ollama

# ─── Ollama Settings (used when LLM_PROVIDER=ollama) ─────────────────────────
# URL of the running Ollama server.
# For Docker: use http://host.docker.internal:11434 to reach the host machine.
OLLAMA_BASE_URL=http://localhost:11434

# Ollama model name. Run 'ollama pull llama3.2' to download before first use.
OLLAMA_MODEL=llama3.2

# ─── OpenAI Settings (used when LLM_PROVIDER=openai) ─────────────────────────
# Your OpenAI API key. Required only when LLM_PROVIDER=openai.
OPENAI_API_KEY=sk-...

# OpenAI model name. gpt-4o gives the best results; gpt-3.5-turbo is cheaper.
OPENAI_MODEL=gpt-4o

# ─── Pipeline Settings ────────────────────────────────────────────────────────
# Directory where chart PNGs and report.md files are saved.
OUTPUT_DIR=./output

# Maximum number of analyzer → reflector loop iterations before forcing approval.
# Increase to allow deeper analysis at the cost of longer runtime.
MAX_REFLECTION_ITERATIONS=2

# Minimum quality score (0-10) that the DataCritic must assign to approve the
# analysis and proceed to report writing. Scores below this trigger re-analysis.
REFLECTION_QUALITY_THRESHOLD=7.0

# ─── API / UI Settings ────────────────────────────────────────────────────────
# Base URL of the FastAPI server, used by the Streamlit UI.
# When running with docker-compose, set this to http://app:8000
API_BASE_URL=http://localhost:8000
