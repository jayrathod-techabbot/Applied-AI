# =============================================================================
# Multi-Agent Customer Support System — Environment Variables
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Configuration
# -----------------------------------------------------------------------------

# Your Groq API key — get one at https://console.groq.com
# Format: gsk_...
GROQ_API_KEY=gsk_your_key_here

# Groq model to use for all LLM calls
# Options: llama-3.3-70b-versatile | llama-3.1-70b-versatile | mixtral-8x7b-32768
GROQ_MODEL=llama-3.3-70b-versatile

# LLM provider (currently only groq is supported)
LLM_PROVIDER=groq

# -----------------------------------------------------------------------------
# Knowledge Base Configuration
# -----------------------------------------------------------------------------

# Directory containing KB markdown files
# Must contain: billing_kb.md, technical_kb.md, general_kb.md
KB_DIR=./data/knowledge_base

# -----------------------------------------------------------------------------
# Agent Behavior
# -----------------------------------------------------------------------------

# Confidence threshold for HITL escalation (0.0 to 1.0)
# Tickets with confidence < this value are escalated to human agents.
# Lower value = fewer escalations (faster but riskier)
# Higher value = more escalations (safer but more human load)
CONFIDENCE_THRESHOLD=0.6

# Maximum number of recent messages to include in session context
# Higher = better context but more tokens consumed per LLM call
MAX_HISTORY_MESSAGES=20
